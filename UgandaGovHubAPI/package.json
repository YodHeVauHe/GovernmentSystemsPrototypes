{
  "name": "uganda-govhub-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:prepare && npm run dev:services",
    "dev:prepare": "npm run db:up && npm run db:wait && npm run seed",
    "dev:services": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "db:up": "node scripts/local-postgres.mjs up",
    "db:wait": "node scripts/local-postgres.mjs wait",
    "db:down": "node scripts/local-postgres.mjs down",
    "db:logs": "node scripts/local-postgres.mjs logs",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "lint": "cd frontend && npm run lint",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:local-startup": "node --test tests/local-dev-scripts.test.mjs",
    "build": "cd frontend && npm run build",
    "seed": "cd backend && npm run seed",
    "demo": "npm run dev",
    "dev:e2e": "concurrently -k \"cd backend && PORT=4000 HOST=127.0.0.1 npm run dev\" \"cd frontend && VITE_API_BASE_URL=http://127.0.0.1:4000 npm run dev -- --host 127.0.0.1 --port 5173 --strictPort\"",
    "test:e2e": "playwright test tests/e2e/ministry-demo.spec.ts",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vercel/node": "^5.8.5",
    "axe-core": "^4.11.4"
  }
}
