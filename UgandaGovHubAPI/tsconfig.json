{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["api/**/*.ts"],
  "exclude": ["backend/src/**/*.test.ts", "frontend", "node_modules"]
}
