HOST=127.0.0.1
PORT=4000
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<database>
DATABASE_SSL=false
# Cloudflare Turnstile test secret for local development only.
GOVHUB_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
GOVHUB_TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1
GOVHUB_ADMIN_EMAIL=<admin-email>
GOVHUB_ADMIN_PASSWORD=<set-a-strong-local-password>
GOVHUB_DEMO_MODE=false
GOVHUB_DEMO_DEVELOPER_EMAIL=<developer-demo-email>
GOVHUB_DEMO_DEVELOPER_PASSWORD=<set-a-strong-local-password>
GOVHUB_DEMO_API_OWNER_EMAIL=<api-owner-demo-email>
GOVHUB_DEMO_API_OWNER_PASSWORD=<set-a-strong-local-password>
GOVHUB_DEMO_REVIEWER_EMAIL=<reviewer-demo-email>
GOVHUB_DEMO_REVIEWER_PASSWORD=<set-a-strong-local-password>
